{
  "name": "proxus-challenge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @proxus/server --filter @proxus/web run dev",
