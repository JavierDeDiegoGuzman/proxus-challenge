{
  "name": "@proxus/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "agent:sum": "node --env-file=../../.env --import tsx src/domain/agents/index.ts",
    "agent:math": "node --env-file=../../.env --import tsx src/domain/agents/math.ts",
    "agent:tutor": "node --env-file=../../.env --import tsx src/domain/agents/academic-tutor.ts",
    "dev": "node --env-file=../../.env --import tsx src/index.ts",
    "eval:tutor:artifact-authoring": "node --env-file=../../.env --import tsx src/domain/agents/academic-tutor/evals/artifact-authoring.eval.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/ai-google": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.83",
    "@proxus/shared": "workspace:*",
    "effect": "4.0.0-beta.83"
  }
}
