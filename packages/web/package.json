{
  "name": "@proxus/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/main.tsx",
  "scripts": {
    "dev": "tailwindcss -i src/styles.input.css -o src/styles.generated.css && sh -c 'tailwindcss -i src/styles.input.css -o src/styles.generated.css --watch & vite; kill $!'",
    "build": "tailwindcss -i src/styles.input.css -o src/styles.generated.css --minify && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.83",
    "@proxus/shared": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "effect": "4.0.0-beta.83",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
